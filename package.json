{
  "name": "v-float",
  "version": "0.10.0",
  "description": "Vue 3 port of Floating UI - a library for positioning floating elements",
  "private": false,
  "type": "module",
  "files": [
    "dist"
  ],
  "types": "./dist/src/index.d.ts",
  "main": "./dist/v-float.umd.js",
  "module": "./dist/v-float.es.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/v-float.es.js",
      "require": "./dist/v-float.umd.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build tsconfig.build.json",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "test": "vitest",
    "test:coverage": "vitest --run --coverage",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "release": "release-it",
    "release:patch": "release-it patch",
    "release:minor": "release-it minor",
    "release:major": "release-it major",
    "release:dry": "release-it --dry-run",
    "changelog": "changelogen",
    "changelog:preview": "changelogen --no-output"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "focus-trap": "^8.0.0",
    "tabbable": "^6.4.0",
    "unocss": "^66.6.7",
    "vue": "^3.5.30"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.2",
    "@tsconfig/node22": "^22.0.5",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.5.0",
    "@unocss/reset": "66.1.0-beta.7",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/browser": "^4.1.0",
    "@vitest/browser-playwright": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vue/tsconfig": "^0.9.0",
    "changelogen": "^0.6.2",
    "jsdom": "^29.0.1",
    "lucide-vue-next": "^0.577.0",
    "npm-run-all2": "^8.0.4",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "release-it": "^19.2.4",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-vue-devtools": "^8.1.0",
    "vitepress": "^1.6.4",
    "vitepress-plugin-demo": "^0.8.1",
    "vitest": "^4.1.0",
    "vitest-browser-vue": "^2.1.0",
    "vue-tsc": "^3.2.6"
  },
  "packageManager": "npm@11.12.0"
}
