{
  "git": {
    "commitMessage": "chore: release v${version}",
    "tagName": "v${version}",
    "pushRepo": "origin",
    "requireBranch": "main"
  },
  "npm": {
    "publish": true,
    "publishPath": "."
  },
  "hooks": {
    "before:init": ["node ./scripts/release/before-init.mjs"],
    "after:bump": ["vp pack", "vp exec changelogen", "git add CHANGELOG.md"],
    "after:release": [
      "vp exec changelogen gh release",
      "echo Successfully released ${name} v${version} to ${repo.repository}."
    ]
  },
  "github": {
    "release": true,
    "releaseName": "v${version}"
  },
  "plugins": {}
}
