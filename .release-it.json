{
  "git": {
    "commitMessage": "chore: release v${version}",
    "tagName": "v${version}",
    "pushRepo": "origin",
    "requireBranch": "main",
    "requireCleanWorkingDir": true
  },
  "npm": {
    "publish": true,
    "publishPath": "."
  },
  "hooks": {
    "before:init": ["node ./scripts/release/before-init.mjs"],
    "before:bump": ["vp check", "vp test"],
    "after:bump": ["vp exec changelogen", "vp pack", "git add package.json CHANGELOG.md"],
    "after:release": ["echo Successfully released ${name} v${version} to ${repo.repository}."]
  },
  "github": {
    "release": true,
    "releaseName": "v${version}",
    "releaseNotes": "node ./scripts/release/release-notes.mjs ${version}"
  },
  "plugins": {}
}
